# GTMetrix API key -- get yours at https://gtmetrix.com/api/
# Copy this file to .env and fill in your actual key
GTMETRIX_API_KEY=your_api_key_here

# Optional: Default test parameters
# If set, these are used when the corresponding tool parameter is not provided.
# Explicit tool parameters always override these defaults.
# GTMETRIX_DEFAULT_LOCATION=1
# GTMETRIX_DEFAULT_BROWSER=3
# GTMETRIX_DEFAULT_DEVICE=phone
# GTMETRIX_DEFAULT_ADBLOCK=0
